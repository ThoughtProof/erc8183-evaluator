# BNBAgent ThoughtProof Integration Configuration

# ============================================================================
# REQUIRED: Wallet Configuration
# ============================================================================

# Password for wallet encryption/decryption (REQUIRED)
WALLET_PASSWORD=your_secure_password_here

# Private key for agent wallet (optional - auto-generates if not provided)
# If provided, it will be imported and encrypted on first run
# PRIVATE_KEY=0x1234567890abcdef...

# Select specific wallet if multiple exist (optional)
# WALLET_ADDRESS=0x...

# ============================================================================
# REQUIRED: Network Configuration  
# ============================================================================

# Network to connect to (default: bsc-testnet)
NETWORK=bsc-testnet

# Custom RPC URL (optional - uses network default if not specified)
# RPC_URL=https://bsc-testnet.bnbchain.org

# ERC-8183 contract address (optional - uses network default if not specified)
# ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6

# ThoughtProof Evaluator contract address (REQUIRED)
THOUGHTPROOF_EVALUATOR=0xf6aa6225fbff02455d51b287a33cc86c75897948

# ============================================================================
# OPTIONAL: ThoughtProof API Configuration
# ============================================================================

# Verification speed: "standard" ($0.008) or "deep" ($0.08)
THOUGHTPROOF_SPEED=standard

# Domain context: "general", "financial", "medical", "legal", "code"
THOUGHTPROOF_DOMAIN=general

# API timeout in seconds
THOUGHTPROOF_TIMEOUT=120

# ============================================================================
# OPTIONAL: Auto-Finalization Configuration
# ============================================================================

# Whether to automatically finalize jobs after verification
AUTO_FINALIZE=true

# Minimum confidence threshold for auto-completion (0.0 - 1.0)
MIN_CONFIDENCE=0.7

# Seconds to wait before auto-finalization
AUTO_FINALIZE_DELAY=30

# Whether to include job context in verification claims
INCLUDE_JOB_CONTEXT=true

# ============================================================================
# OPTIONAL: Error Handling Configuration
# ============================================================================

# Maximum retry attempts for API calls
MAX_RETRIES=3

# Whether to allow jobs through if ThoughtProof API fails
FALLBACK_ON_API_ERROR=false

# ============================================================================
# OPTIONAL: Agent Server Configuration
# ============================================================================

# Server host and port
HOST=0.0.0.0
PORT=8000

# Job processing timeout in seconds
JOB_TIMEOUT=300

# ============================================================================
# OPTIONAL: Agent Business Configuration  
# ============================================================================

# Default service price in token smallest unit (e.g., wei for ETH-based tokens)
SERVICE_PRICE=1000000000000000000

# Payment token decimal places
PAYMENT_TOKEN_DECIMALS=18

# ============================================================================
# OPTIONAL: Storage Configuration
# ============================================================================

# Storage provider: "local" or "ipfs"
STORAGE_PROVIDER=local

# Local storage directory (for local provider)
# STORAGE_LOCAL_DIR=./storage

# IPFS configuration (for IPFS provider)  
# STORAGE_IPFS_HOST=127.0.0.1
# STORAGE_IPFS_PORT=5001
# STORAGE_IPFS_PROTOCOL=http

# ============================================================================
# Example Network Configurations
# ============================================================================

# BSC Testnet
# NETWORK=bsc-testnet
# RPC_URL=https://bsc-testnet.bnbchain.org
# ERC8183_ADDRESS=0x3464e64dD53bC093c53050cE5114062765e9F1b6

# BSC Mainnet
# NETWORK=bsc-mainnet  
# RPC_URL=https://bsc-dataseed1.binance.org
# ERC8183_ADDRESS=0x...

# Base Mainnet
# NETWORK=base-mainnet
# RPC_URL=https://mainnet.base.org
# THOUGHTPROOF_EVALUATOR=0xf6aa6225fbff02455d51b287a33cc86c75897948

# Ethereum Mainnet
# NETWORK=ethereum-mainnet
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
# ERC8183_ADDRESS=0x...